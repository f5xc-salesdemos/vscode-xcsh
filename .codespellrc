[codespell]
skip = *.json,*.lock,*/tools/generated/*,vendor/*,*/vendored/*,*-vendored*,*/fixtures/*,*.min.js,*.jsonl,*.b64.js,*/gen/*,node_modules,target,dist,.git,packages/*/dist,crates/*/vendored,*.generated.ts,pnpm-lock.yaml,docs/fr,docs/es,docs/de,docs/ja,docs/pt-br,docs/ko,docs/zh-cn,docs/zh-tw,docs/ar,docs/it,docs/hi,docs/th,README.ar.md,README.de.md,README.es.md,README.fr.md,README.hi.md,README.it.md,README.ja.md,README.ko.md,README.pt-br.md,README.th.md,README.zh-cn.md,README.zh-tw.md,config/spelling_corrections.yaml,config/property_name_corrections.yaml,docs/specifications/*,src/generated/*,out/*
ignore-words-list = afterall,aks,datas,deliverys,edn,hcl,ists,iterm,pre-select,pre-selected,pre-selects,uncomplete,ves,doesnt,forin,statics,ser,anc,crossreferences,prevend,aline,invokable,takin,hel,unparseable,defaul,atmost,atleast,adn,checkin,hashi,devlop,trough
