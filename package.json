  "scripts": {
    "vscode:prepublish": "npm run package",
    "generate:docs": "npx ts-node scripts/generate-doc-urls.ts",
    "generate:types": "npx ts-node scripts/generate-resource-types.ts",
    "generate:menu-schema": "npx ts-node scripts/generators/menu-schema-generator.ts",
    "generate": "npm run generate:types && npm run generate:docs && npm run generate:menu-schema",
    "validate:generation": "npx ts-node scripts/validate-generation.ts",
    "validate:forms": "npx ts-node scripts/validate-form-defaults.ts",
    "validate:i18n": "npx @vscode/l10n-dev export -o ./l10n ./src",
    "validate:i18n-coverage": "npx tsx scripts/validate-i18n-coverage.mts",
    "compile": "npm run generate && webpack",
    "watch": "npm run generate && webpack --watch",
    "package": "npm run generate && npm run build:webview && webpack --mode production --devtool hidden-source-map",
    "build:webview": "cd webview && npx vite build",
    "dev:webview": "cd webview && npx vite",
    "build:ci-local": "npm ci && npm run specs:ensure && npm run generate && npm run package && npx @vscode/vsce package --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint && npm run validate:forms",
    "lint": "eslint src scripts webview/src",
    "lint:fix": "eslint src scripts webview/src --fix",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:integration": "npm run compile-tests && vscode-test",
    "test:coverage": "jest --coverage",
    "test:all": "npm run test:unit && npm run test:integration",
    "version:show": "npx ts-node scripts/version.ts",
    "version:beta": "npx ts-node scripts/version.ts --beta",
    "version:update": "npx ts-node scripts/version.ts --update",
    "version:json": "npx ts-node scripts/version.ts --json",
    "specs:check": "npx ts-node scripts/check-specs.ts --check",
    "specs:sync": "npx ts-node scripts/sync-specs.ts",
    "specs:status": "npx ts-node scripts/check-specs.ts --json",
    "specs:ensure": "npx ts-node scripts/check-specs.ts --sync",
    "pregenerate": "npm run specs:ensure",
    "clean": "rimraf dist out coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "audit:security": "npm audit --audit-level=high"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "biome check --fix",
      "biome format --write"
    ],
    "*.{json,yaml,yml}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint --fix"
    ]
  },
