{
  "name": "xcsh",
  "displayName": "xcsh",
  "description": "Agentic Platform Shell",
  "version": "2.2606.230957",
  "publisher": "f5xc-salesdemos",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/f5xc-salesdemos/vscode-f5xc-tools"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "f5",
    "distributed cloud",
    "xcsh",
    "xc",
    "kubernetes",
    "load balancer",
    "waf",
    "cdn"
  ],
  "icon": "resources/f5-icon.png",
  "galleryBanner": {
    "color": "#e01f27",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "xcsh.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "%config.logLevel.description%"
        },
        "xcsh.defaultNamespace": {
          "type": "string",
          "default": "default",
          "description": "%config.defaultNamespace.description%"
        },
        "xcsh.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "%config.confirmDelete.description%"
        },
        "xcsh.deleteConfirmationLevel": {
          "type": "string",
          "enum": [
            "always",
            "high-only",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "%config.deleteConfirmationLevel.always%",
            "%config.deleteConfirmationLevel.highOnly%",
            "%config.deleteConfirmationLevel.never%"
          ],
          "description": "%config.deleteConfirmationLevel.description%"
        },
        "xcsh.autoRefreshInterval": {
          "type": "number",
          "default": 0,
          "description": "%config.autoRefreshInterval.description%"
        },
        "xcsh.viewMode": {
          "type": "string",
          "enum": [
            "console",
            "full"
          ],
          "default": "console",
          "description": "%config.viewMode.description%"
        },
        "xcsh.showPreviewApis": {
          "type": "boolean",
          "default": true,
          "description": "%config.showPreviewApis.description%"
        },
        "xcsh.xcsh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.enabled.description%"
        },
        "xcsh.xcsh.path": {
          "type": "string",
          "default": "",
          "description": "%config.xcsh.path.description%"
        },
        "xcsh.xcsh.chatParticipantEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.chatParticipant.description%"
        },
        "xcsh.xcsh.languageModelEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.languageModel.description%"
        },
        "xcsh.xcsh.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.autoStart.description%"
        },
        "xcsh.xcsh.defaultModel": {
          "type": "string",
          "default": "",
          "description": "%config.xcsh.defaultModel.description%"
        },
        "xcsh.xcsh.thinkingLevel": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "medium",
          "description": "%config.xcsh.thinkingLevel.description%"
        },
        "xcsh.xcsh.panelMode": {
          "type": "string",
          "enum": [
            "webview",
            "terminal"
          ],
          "default": "webview",
          "enumDescriptions": [
            "%config.xcsh.panelMode.webview%",
            "%config.xcsh.panelMode.terminal%"
          ],
          "description": "%config.xcsh.panelMode.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xcsh-explorer",
          "title": "xcsh",
          "icon": "resources/f5-activitybar.svg"
        },
        {
          "id": "xcsh-panel",
          "title": "xcsh",
          "icon": "resources/f5-activitybar.svg",
          "when": "xcsh:doesNotSupportSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "xcsh-panel-secondary",
          "title": "xcsh",
          "icon": "resources/f5-activitybar.svg",
          "when": "!xcsh:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "xcsh-panel": [
        {
          "id": "xcsh.xcshPanel",
          "name": "xcsh",
          "type": "webview",
          "when": "xcsh:doesNotSupportSecondarySidebar"
        }
      ],
      "xcsh-panel-secondary": [
        {
          "id": "xcsh.xcshPanelSecondary",
          "name": "xcsh",
          "type": "webview",
          "when": "!xcsh:doesNotSupportSecondarySidebar"
        }
      ],
      "xcsh-explorer": [
        {
          "id": "xcsh.profiles",
          "name": "%view.profiles.name%",
          "contextualTitle": "%view.profiles.contextualTitle%"
        },
        {
          "id": "xcsh.subscription",
          "name": "%view.subscription.name%",
          "contextualTitle": "%view.subscription.contextualTitle%",
          "when": "xcsh.hasActiveContext"
        },
        {
          "id": "xcsh.explorer",
          "name": "%view.explorer.name%",
          "contextualTitle": "%view.explorer.contextualTitle%"
        },
        {
          "id": "xcsh.cloudStatus",
          "name": "%view.cloudStatus.name%",
          "contextualTitle": "%view.cloudStatus.contextualTitle%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "xcsh.explorer",
        "contents": "%viewsWelcome.explorer%",
        "when": "!xcsh.hasActiveContext"
      }
    ],
    "commands": [
      {
        "command": "xcsh.addContext",
        "title": "%command.addContext.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "xcsh.editContext",
        "title": "%command.editContext.title%",
        "category": "xcsh",
        "icon": "$(edit)"
      },
      {
        "command": "xcsh.deleteContext",
        "title": "%command.deleteContext.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "xcsh.setActiveContext",
        "title": "%command.setActiveContext.title%",
        "category": "xcsh",
        "icon": "$(check)"
      },
      {
        "command": "xcsh.clearAuthCache",
        "title": "%command.clearAuthCache.title%",
        "category": "xcsh",
        "icon": "$(clear-all)"
      },
      {
        "command": "xcsh.refresh",
        "title": "%command.refresh.title%",
        "category": "xcsh",
        "icon": "$(refresh)"
      },
      {
        "command": "xcsh.create",
        "title": "%command.create.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "xcsh.get",
        "title": "%command.get.title%",
        "category": "xcsh",
        "icon": "$(eye)"
      },
      {
        "command": "xcsh.describe",
        "title": "%command.describe.title%",
        "category": "xcsh",
        "icon": "$(info)"
      },
      {
        "command": "xcsh.edit",
        "title": "%command.edit.title%",
        "category": "xcsh",
        "icon": "$(edit)"
      },
      {
        "command": "xcsh.delete",
        "title": "%command.delete.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "xcsh.deleteNamespace",
        "title": "%command.deleteNamespace.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "xcsh.describeNamespace",
        "title": "%command.describeNamespace.title%",
        "category": "xcsh",
        "icon": "$(info)"
      },
      {
        "command": "xcsh.apply",
        "title": "%command.apply.title%",
        "category": "xcsh",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "xcsh.diff",
        "title": "%command.diff.title%",
        "category": "xcsh",
        "icon": "$(diff)"
      },
      {
        "command": "xcsh.copyName",
        "title": "%command.copyName.title%",
        "category": "xcsh"
      },
      {
        "command": "xcsh.copyAsJson",
        "title": "%command.copyAsJson.title%",
        "category": "xcsh"
      },
      {
        "command": "xcsh.viewLogs",
        "title": "%command.viewLogs.title%",
        "category": "xcsh",
        "icon": "$(output)"
      },
      {
        "command": "xcsh.viewMetrics",
        "title": "%command.viewMetrics.title%",
        "category": "xcsh",
        "icon": "$(graph)"
      },
      {
        "command": "xcsh.diagram",
        "title": "%command.diagram.title%",
        "category": "xcsh",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "xcsh.createFromTemplate",
        "title": "%command.createFromTemplate.title%",
        "category": "xcsh",
        "icon": "$(file-add)"
      },
      {
        "command": "xcsh.openInBrowser",
        "title": "%command.openInBrowser.title%",
        "category": "xcsh",
        "icon": "$(link-external)"
      },
      {
        "command": "xcsh.exportJson",
        "title": "%command.exportJson.title%",
        "category": "xcsh",
        "icon": "$(file-code)"
      },
      {
        "command": "xcsh.exportYaml",
        "title": "%command.exportYaml.title%",
        "category": "xcsh",
        "icon": "$(file-code)"
      },
      {
        "command": "xcsh.exportAllJson",
        "title": "%command.exportAllJson.title%",
        "category": "xcsh",
        "icon": "$(files)"
      },
      {
        "command": "xcsh.exportAllYaml",
        "title": "%command.exportAllYaml.title%",
        "category": "xcsh",
        "icon": "$(files)"
      },
      {
        "command": "xcsh.fileApply",
        "title": "%command.fileApply.title%",
        "category": "xcsh",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "xcsh.fileCreate",
        "title": "%command.fileCreate.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "xcsh.fileDiff",
        "title": "%command.fileDiff.title%",
        "category": "xcsh",
        "icon": "$(diff)"
      },
      {
        "command": "xcsh.fileDelete",
        "title": "%command.fileDelete.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "xcsh.toggleViewMode",
        "title": "%command.toggleViewMode.title%",
        "category": "xcsh",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "xcsh.cloudStatus.refresh",
        "title": "%command.cloudStatus.refresh.title%",
        "category": "xcsh",
        "icon": "$(refresh)"
      },
      {
        "command": "xcsh.cloudStatus.openDashboard",
        "title": "%command.cloudStatus.openDashboard.title%",
        "category": "xcsh",
        "icon": "$(dashboard)"
      },
      {
        "command": "xcsh.showOnboarding",
        "title": "%command.showOnboarding.title%",
        "category": "xcsh",
        "icon": "$(checklist)"
      },
      {
        "command": "xcsh.cloudStatus.openExternal",
        "title": "%command.cloudStatus.openExternal.title%",
        "category": "xcsh",
        "icon": "$(link-external)"
      },
      {
        "command": "xcsh.cloudStatus.viewMaintenance",
        "title": "%command.cloudStatus.viewMaintenance.title%",
        "category": "xcsh",
        "icon": "$(info)"
      },
      {
        "command": "xcsh.cloudStatus.viewIncident",
        "title": "%command.cloudStatus.viewIncident.title%",
        "category": "xcsh",
        "icon": "$(warning)"
      },
      {
        "command": "xcsh.cloudStatus.viewComponent",
        "title": "%command.cloudStatus.viewComponent.title%",
        "category": "xcsh",
        "icon": "$(server)"
      },
      {
        "command": "xcsh.cloudStatus.viewPoP",
        "title": "%command.cloudStatus.viewPoP.title%",
        "category": "xcsh",
        "icon": "$(globe)"
      },
      {
        "command": "xcsh.showPlan",
        "title": "%command.showPlan.title%",
        "category": "xcsh",
        "icon": "$(file-text)"
      },
      {
        "command": "xcsh.showQuotas",
        "title": "%command.showQuotas.title%",
        "category": "xcsh",
        "icon": "$(graph)"
      },
      {
        "command": "xcsh.activateAddon",
        "title": "%command.activateAddon.title%",
        "category": "xcsh",
        "icon": "$(rocket)"
      },
      {
        "command": "xcsh.createHealthcheckForm",
        "title": "%command.createHealthcheckForm.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "xcsh.xcsh.openTerminal",
        "title": "%command.xcsh.openTerminal.title%",
        "category": "xcsh",
        "icon": "$(terminal)"
      },
      {
        "command": "xcsh.xcsh.restart",
        "title": "%command.xcsh.restart.title%",
        "category": "xcsh",
        "icon": "$(debug-restart)"
      },
      {
        "command": "xcsh.xcsh.openPanel",
        "title": "%command.xcsh.openPanel.title%",
        "category": "xcsh",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "xcsh.xcsh.newSession",
        "title": "%command.xcsh.newSession.title%",
        "category": "xcsh",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xcsh.refresh",
          "when": "view == xcsh.explorer",
          "group": "navigation@1"
        },
        {
          "command": "xcsh.addContext",
          "when": "view == xcsh.profiles",
          "group": "navigation"
        },
        {
          "command": "xcsh.cloudStatus.refresh",
          "when": "view == xcsh.cloudStatus",
          "group": "navigation@1"
        },
        {
          "command": "xcsh.cloudStatus.openDashboard",
          "when": "view == xcsh.cloudStatus",
          "group": "navigation@2"
        },
        {
          "command": "xcsh.cloudStatus.openExternal",
          "when": "view == xcsh.cloudStatus",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "xcsh.setActiveContext",
          "when": "view == xcsh.profiles && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "xcsh.editContext",
          "when": "view == xcsh.profiles && viewItem == profile",
          "group": "1_profile@1"
        },
        {
          "command": "xcsh.deleteContext",
          "when": "view == xcsh.profiles && viewItem == profile",
          "group": "1_profile@2"
        },
        {
          "command": "xcsh.refresh",
          "when": "view == xcsh.explorer && viewItem =~ /namespace|category/",
          "group": "inline"
        },
        {
          "command": "xcsh.create",
          "when": "view == xcsh.explorer && viewItem =~ /resourceType/ && viewItem != resourceType:healthcheck",
          "group": "inline"
        },
        {
          "command": "xcsh.createHealthcheckForm",
          "when": "view == xcsh.explorer && viewItem == resourceType:healthcheck",
          "group": "inline"
        },
        {
          "command": "xcsh.createHealthcheckForm",
          "when": "view == xcsh.explorer && viewItem == resourceType:healthcheck",
          "group": "1_create@1"
        },
        {
          "command": "xcsh.describe",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "1_resource@1"
        },
        {
          "command": "xcsh.get",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "1_resource@2"
        },
        {
          "command": "xcsh.edit",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "1_resource@3"
        },
        {
          "command": "xcsh.delete",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "1_resource@4"
        },
        {
          "command": "xcsh.deleteNamespace",
          "when": "view == xcsh.explorer && viewItem == namespace:custom",
          "group": "1_namespace@1"
        },
        {
          "command": "xcsh.describeNamespace",
          "when": "view == xcsh.explorer && viewItem =~ /namespace:/",
          "group": "1_namespace@2"
        },
        {
          "command": "xcsh.diff",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "2_compare@1"
        },
        {
          "command": "xcsh.copyName",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "3_copy@1"
        },
        {
          "command": "xcsh.copyAsJson",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "3_copy@2"
        },
        {
          "command": "xcsh.viewLogs",
          "when": "view == xcsh.explorer && viewItem =~ /resource:http_loadbalancer|resource:tcp_loadbalancer/",
          "group": "4_observe@1"
        },
        {
          "command": "xcsh.viewMetrics",
          "when": "view == xcsh.explorer && viewItem =~ /resource:http_loadbalancer|resource:tcp_loadbalancer|resource:origin_pool/",
          "group": "4_observe@2"
        },
        {
          "command": "xcsh.diagram",
          "when": "view == xcsh.explorer && viewItem =~ /resource:http_loadbalancer/",
          "group": "4_observe@3"
        },
        {
          "command": "xcsh.openInBrowser",
          "when": "view == xcsh.explorer && viewItem =~ /resource:/",
          "group": "5_external@1"
        },
        {
          "command": "xcsh.exportJson",
          "when": "view == xcsh.explorer && viewItem =~ /^resource:/",
          "group": "6_export@1"
        },
        {
          "command": "xcsh.exportYaml",
          "when": "view == xcsh.explorer && viewItem =~ /^resource:/",
          "group": "6_export@2"
        },
        {
          "command": "xcsh.exportAllJson",
          "when": "view == xcsh.explorer && viewItem =~ /^resourceType:/",
          "group": "6_export@1"
        },
        {
          "command": "xcsh.exportAllYaml",
          "when": "view == xcsh.explorer && viewItem =~ /^resourceType:/",
          "group": "6_export@2"
        },
        {
          "command": "xcsh.showPlan",
          "when": "view == xcsh.subscription && viewItem == subscriptionPlan",
          "group": "inline"
        },
        {
          "command": "xcsh.showQuotas",
          "when": "view == xcsh.subscription && viewItem == subscriptionQuotas",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "xcsh.fileApply",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "xcsh@1"
        },
        {
          "command": "xcsh.fileCreate",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "xcsh@2"
        },
        {
          "command": "xcsh.fileDiff",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "xcsh@3"
        },
        {
          "command": "xcsh.fileDelete",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "xcsh@4"
        }
      ],
      "editor/title": [
        {
          "command": "xcsh.apply",
          "when": "resourceExtname == .xcsh.json || resourceFilename =~ /.*\\.(http_loadbalancer|origin_pool|app_firewall)\\.json$/",
          "group": "navigation"
        },
        {
          "command": "xcsh.diff",
          "when": "resourceExtname == .xcsh.json || resourceFilename =~ /.*\\.(http_loadbalancer|origin_pool|app_firewall)\\.json$/",
          "group": "navigation"
        },
        {
          "command": "xcsh.fileApply",
          "when": "xcsh.isManifestFile",
          "group": "xcsh@1"
        },
        {
          "command": "xcsh.fileDiff",
          "when": "xcsh.isManifestFile",
          "group": "xcsh@2"
        }
      ],
      "commandPalette": [
        {
          "command": "xcsh.setActiveContext",
          "when": "false"
        },
        {
          "command": "xcsh.copyName",
          "when": "false"
        },
        {
          "command": "xcsh.copyAsJson",
          "when": "false"
        },
        {
          "command": "xcsh.fileApply",
          "when": "false"
        },
        {
          "command": "xcsh.fileCreate",
          "when": "false"
        },
        {
          "command": "xcsh.fileDiff",
          "when": "false"
        },
        {
          "command": "xcsh.fileDelete",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "xcsh.apply",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && resourceExtname == .json"
      },
      {
        "command": "xcsh.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view == xcsh.explorer"
      }
    ],
    "languageModelTools": [
      {
        "name": "xcsh-readFile",
        "displayName": "%tool.readFile.displayName%",
        "modelDescription": "Read the contents of a file in the workspace. Use when you need to examine source code, configuration files, or any text file. Returns the full file content as text.",
        "userDescription": "%tool.readFile.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "readFile",
        "icon": "$(file)",
        "tags": [
          "xcsh"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or workspace-relative file path"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "xcsh-getSelection",
        "displayName": "%tool.getSelection.displayName%",
        "modelDescription": "Get the currently selected text in the active editor. Use when the user references 'this code' or 'selected text'. Returns empty string if no selection.",
        "userDescription": "%tool.getSelection.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "getSelection",
        "icon": "$(selection)",
        "tags": [
          "xcsh"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "xcsh-getDiagnostics",
        "displayName": "%tool.getDiagnostics.displayName%",
        "modelDescription": "Get compiler errors, warnings, and linter diagnostics for a specific file. Use when investigating build errors or code quality issues. Returns an array of diagnostics with severity, line number, message, and source.",
        "userDescription": "%tool.getDiagnostics.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "diagnostics",
        "icon": "$(warning)",
        "tags": [
          "xcsh"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or workspace-relative file path"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "xcsh-openFile",
