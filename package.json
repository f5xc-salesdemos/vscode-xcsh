{
  "name": "xcsh",
  "displayName": "xcsh",
  "description": "Agentic Platform Shell",
  "version": "2.2606.121627",
  "publisher": "f5xc-salesdemos",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/f5xc-salesdemos/vscode-f5xc-tools"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "f5",
    "distributed cloud",
    "f5xc",
    "xc",
    "kubernetes",
    "load balancer",
    "waf",
    "cdn"
  ],
  "icon": "resources/f5-icon.png",
  "galleryBanner": {
    "color": "#e01f27",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "f5xc.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "%config.logLevel.description%"
        },
        "f5xc.defaultNamespace": {
          "type": "string",
          "default": "default",
          "description": "%config.defaultNamespace.description%"
        },
        "f5xc.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "%config.confirmDelete.description%"
        },
        "f5xc.deleteConfirmationLevel": {
          "type": "string",
          "enum": [
            "always",
            "high-only",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "%config.deleteConfirmationLevel.always%",
            "%config.deleteConfirmationLevel.highOnly%",
            "%config.deleteConfirmationLevel.never%"
          ],
          "description": "%config.deleteConfirmationLevel.description%"
        },
        "f5xc.autoRefreshInterval": {
          "type": "number",
          "default": 0,
          "description": "%config.autoRefreshInterval.description%"
        },
        "f5xc.viewMode": {
          "type": "string",
          "enum": [
            "console",
            "full"
          ],
          "default": "console",
          "description": "%config.viewMode.description%"
        },
        "f5xc.showPreviewApis": {
          "type": "boolean",
          "default": true,
          "description": "%config.showPreviewApis.description%"
        },
        "f5xc.xcsh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.enabled.description%"
        },
        "f5xc.xcsh.path": {
          "type": "string",
          "default": "",
          "description": "%config.xcsh.path.description%"
        },
        "f5xc.xcsh.chatParticipantEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.chatParticipant.description%"
        },
        "f5xc.xcsh.languageModelEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.languageModel.description%"
        },
        "f5xc.xcsh.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%config.xcsh.autoStart.description%"
        },
        "f5xc.xcsh.defaultModel": {
          "type": "string",
          "default": "",
          "description": "%config.xcsh.defaultModel.description%"
        },
        "f5xc.xcsh.thinkingLevel": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "medium",
          "description": "%config.xcsh.thinkingLevel.description%"
        },
        "f5xc.xcsh.panelMode": {
          "type": "string",
          "enum": [
            "webview",
            "terminal"
          ],
          "default": "webview",
          "enumDescriptions": [
            "%config.xcsh.panelMode.webview%",
            "%config.xcsh.panelMode.terminal%"
          ],
          "description": "%config.xcsh.panelMode.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "f5xc-explorer",
          "title": "xcsh",
          "icon": "resources/f5-activitybar.svg"
        },
        {
          "id": "xcsh-panel",
          "title": "xcsh",
          "icon": "resources/f5-activitybar.svg",
          "when": "f5xc:doesNotSupportSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "xcsh-panel-secondary",
          "title": "xcsh",
          "icon": "resources/f5-activitybar.svg",
          "when": "!f5xc:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "xcsh-panel": [
        {
          "id": "f5xc.xcshPanel",
          "name": "xcsh",
          "type": "webview",
          "when": "f5xc:doesNotSupportSecondarySidebar"
        }
      ],
      "xcsh-panel-secondary": [
        {
          "id": "f5xc.xcshPanelSecondary",
          "name": "xcsh",
          "type": "webview",
          "when": "!f5xc:doesNotSupportSecondarySidebar"
        }
      ],
      "f5xc-explorer": [
        {
          "id": "f5xc.profiles",
          "name": "%view.profiles.name%",
          "contextualTitle": "%view.profiles.contextualTitle%"
        },
        {
          "id": "f5xc.subscription",
          "name": "%view.subscription.name%",
          "contextualTitle": "%view.subscription.contextualTitle%",
          "when": "f5xc.hasActiveContext"
        },
        {
          "id": "f5xc.explorer",
          "name": "%view.explorer.name%",
          "contextualTitle": "%view.explorer.contextualTitle%"
        },
        {
          "id": "f5xc.cloudStatus",
          "name": "%view.cloudStatus.name%",
          "contextualTitle": "%view.cloudStatus.contextualTitle%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "f5xc.explorer",
        "contents": "%viewsWelcome.explorer%",
        "when": "!f5xc.hasActiveContext"
      }
    ],
    "commands": [
      {
        "command": "f5xc.addContext",
        "title": "%command.addContext.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "f5xc.editContext",
        "title": "%command.editContext.title%",
        "category": "xcsh",
        "icon": "$(edit)"
      },
      {
        "command": "f5xc.deleteContext",
        "title": "%command.deleteContext.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "f5xc.setActiveContext",
        "title": "%command.setActiveContext.title%",
        "category": "xcsh",
        "icon": "$(check)"
      },
      {
        "command": "f5xc.clearAuthCache",
        "title": "%command.clearAuthCache.title%",
        "category": "xcsh",
        "icon": "$(clear-all)"
      },
      {
        "command": "f5xc.refresh",
        "title": "%command.refresh.title%",
        "category": "xcsh",
        "icon": "$(refresh)"
      },
      {
        "command": "f5xc.create",
        "title": "%command.create.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "f5xc.get",
        "title": "%command.get.title%",
        "category": "xcsh",
        "icon": "$(eye)"
      },
      {
        "command": "f5xc.describe",
        "title": "%command.describe.title%",
        "category": "xcsh",
        "icon": "$(info)"
      },
      {
        "command": "f5xc.edit",
        "title": "%command.edit.title%",
        "category": "xcsh",
        "icon": "$(edit)"
      },
      {
        "command": "f5xc.delete",
        "title": "%command.delete.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "f5xc.deleteNamespace",
        "title": "%command.deleteNamespace.title%",
        "category": "xcsh",
        "icon": "$(trash)"
      },
      {
        "command": "f5xc.describeNamespace",
        "title": "%command.describeNamespace.title%",
        "category": "xcsh",
        "icon": "$(info)"
      },
      {
        "command": "f5xc.apply",
        "title": "%command.apply.title%",
        "category": "xcsh",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "f5xc.diff",
        "title": "%command.diff.title%",
        "category": "xcsh",
        "icon": "$(diff)"
      },
      {
        "command": "f5xc.copyName",
        "title": "%command.copyName.title%",
        "category": "xcsh"
      },
      {
        "command": "f5xc.copyAsJson",
        "title": "%command.copyAsJson.title%",
        "category": "xcsh"
      },
      {
        "command": "f5xc.viewLogs",
        "title": "%command.viewLogs.title%",
        "category": "xcsh",
        "icon": "$(output)"
      },
      {
        "command": "f5xc.viewMetrics",
        "title": "%command.viewMetrics.title%",
        "category": "xcsh",
        "icon": "$(graph)"
      },
      {
        "command": "f5xc.diagram",
        "title": "%command.diagram.title%",
        "category": "xcsh",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "f5xc.createFromTemplate",
        "title": "%command.createFromTemplate.title%",
        "category": "xcsh",
        "icon": "$(file-add)"
      },
      {
        "command": "f5xc.openInBrowser",
        "title": "%command.openInBrowser.title%",
        "category": "xcsh",
        "icon": "$(link-external)"
      },
      {
        "command": "f5xc.toggleViewMode",
        "title": "%command.toggleViewMode.title%",
        "category": "xcsh",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "f5xc.cloudStatus.refresh",
        "title": "%command.cloudStatus.refresh.title%",
        "category": "xcsh",
        "icon": "$(refresh)"
      },
      {
        "command": "f5xc.cloudStatus.openDashboard",
        "title": "%command.cloudStatus.openDashboard.title%",
        "category": "xcsh",
        "icon": "$(dashboard)"
      },
      {
        "command": "f5xc.showOnboarding",
        "title": "%command.showOnboarding.title%",
        "category": "xcsh",
        "icon": "$(checklist)"
      },
      {
        "command": "f5xc.cloudStatus.openExternal",
        "title": "%command.cloudStatus.openExternal.title%",
        "category": "xcsh",
        "icon": "$(link-external)"
      },
      {
        "command": "f5xc.cloudStatus.viewMaintenance",
        "title": "%command.cloudStatus.viewMaintenance.title%",
        "category": "xcsh",
        "icon": "$(info)"
      },
      {
        "command": "f5xc.cloudStatus.viewIncident",
        "title": "%command.cloudStatus.viewIncident.title%",
        "category": "xcsh",
        "icon": "$(warning)"
      },
      {
        "command": "f5xc.cloudStatus.viewComponent",
        "title": "%command.cloudStatus.viewComponent.title%",
        "category": "xcsh",
        "icon": "$(server)"
      },
      {
        "command": "f5xc.cloudStatus.viewPoP",
        "title": "%command.cloudStatus.viewPoP.title%",
        "category": "xcsh",
        "icon": "$(globe)"
      },
      {
        "command": "f5xc.showPlan",
        "title": "%command.showPlan.title%",
        "category": "xcsh",
        "icon": "$(file-text)"
      },
      {
        "command": "f5xc.showQuotas",
        "title": "%command.showQuotas.title%",
        "category": "xcsh",
        "icon": "$(graph)"
      },
      {
        "command": "f5xc.activateAddon",
        "title": "%command.activateAddon.title%",
        "category": "xcsh",
        "icon": "$(rocket)"
      },
      {
        "command": "f5xc.createHealthcheckForm",
        "title": "%command.createHealthcheckForm.title%",
        "category": "xcsh",
        "icon": "$(add)"
      },
      {
        "command": "f5xc.xcsh.openTerminal",
        "title": "%command.xcsh.openTerminal.title%",
        "category": "xcsh",
        "icon": "$(terminal)"
      },
      {
        "command": "f5xc.xcsh.restart",
        "title": "%command.xcsh.restart.title%",
        "category": "xcsh",
        "icon": "$(debug-restart)"
      },
      {
        "command": "f5xc.xcsh.openPanel",
        "title": "%command.xcsh.openPanel.title%",
        "category": "xcsh",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "f5xc.xcsh.newSession",
        "title": "%command.xcsh.newSession.title%",
        "category": "xcsh",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "f5xc.refresh",
          "when": "view == f5xc.explorer",
          "group": "navigation@1"
        },
        {
          "command": "f5xc.addContext",
          "when": "view == f5xc.profiles",
          "group": "navigation"
        },
        {
          "command": "f5xc.cloudStatus.refresh",
          "when": "view == f5xc.cloudStatus",
          "group": "navigation@1"
        },
        {
          "command": "f5xc.cloudStatus.openDashboard",
          "when": "view == f5xc.cloudStatus",
          "group": "navigation@2"
        },
        {
          "command": "f5xc.cloudStatus.openExternal",
          "when": "view == f5xc.cloudStatus",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "f5xc.setActiveContext",
          "when": "view == f5xc.profiles && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "f5xc.editContext",
          "when": "view == f5xc.profiles && viewItem == profile",
          "group": "1_profile@1"
        },
        {
          "command": "f5xc.deleteContext",
          "when": "view == f5xc.profiles && viewItem == profile",
          "group": "1_profile@2"
        },
        {
          "command": "f5xc.refresh",
          "when": "view == f5xc.explorer && viewItem =~ /namespace|category/",
          "group": "inline"
        },
        {
          "command": "f5xc.create",
          "when": "view == f5xc.explorer && viewItem =~ /resourceType/ && viewItem != resourceType:healthcheck",
          "group": "inline"
        },
        {
          "command": "f5xc.createHealthcheckForm",
          "when": "view == f5xc.explorer && viewItem == resourceType:healthcheck",
          "group": "inline"
        },
        {
          "command": "f5xc.createHealthcheckForm",
          "when": "view == f5xc.explorer && viewItem == resourceType:healthcheck",
          "group": "1_create@1"
        },
        {
          "command": "f5xc.describe",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@1"
        },
        {
          "command": "f5xc.get",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@2"
        },
        {
          "command": "f5xc.edit",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@3"
        },
        {
          "command": "f5xc.delete",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@4"
        },
        {
          "command": "f5xc.deleteNamespace",
          "when": "view == f5xc.explorer && viewItem == namespace:custom",
          "group": "1_namespace@1"
        },
        {
          "command": "f5xc.describeNamespace",
          "when": "view == f5xc.explorer && viewItem =~ /namespace:/",
          "group": "1_namespace@2"
        },
        {
          "command": "f5xc.diff",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "2_compare@1"
        },
        {
          "command": "f5xc.copyName",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "3_copy@1"
        },
        {
          "command": "f5xc.copyAsJson",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "3_copy@2"
        },
        {
          "command": "f5xc.viewLogs",
          "when": "view == f5xc.explorer && viewItem =~ /resource:http_loadbalancer|resource:tcp_loadbalancer/",
          "group": "4_observe@1"
        },
        {
          "command": "f5xc.viewMetrics",
          "when": "view == f5xc.explorer && viewItem =~ /resource:http_loadbalancer|resource:tcp_loadbalancer|resource:origin_pool/",
          "group": "4_observe@2"
        },
        {
          "command": "f5xc.diagram",
          "when": "view == f5xc.explorer && viewItem =~ /resource:http_loadbalancer/",
          "group": "4_observe@3"
        },
        {
          "command": "f5xc.openInBrowser",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "5_external@1"
        },
        {
          "command": "f5xc.showPlan",
          "when": "view == f5xc.subscription && viewItem == subscriptionPlan",
          "group": "inline"
        },
        {
          "command": "f5xc.showQuotas",
          "when": "view == f5xc.subscription && viewItem == subscriptionQuotas",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "f5xc.apply",
          "when": "resourceExtname == .f5xc.json || resourceFilename =~ /.*\\.(http_loadbalancer|origin_pool|app_firewall)\\.json$/",
          "group": "navigation"
        },
        {
          "command": "f5xc.diff",
          "when": "resourceExtname == .f5xc.json || resourceFilename =~ /.*\\.(http_loadbalancer|origin_pool|app_firewall)\\.json$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "f5xc.setActiveContext",
          "when": "false"
        },
        {
          "command": "f5xc.copyName",
          "when": "false"
        },
        {
          "command": "f5xc.copyAsJson",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "f5xc.apply",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && resourceExtname == .json"
      },
      {
        "command": "f5xc.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view == f5xc.explorer"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.f5xc.json",
        "url": "f5xc-schema://schemas/generic.json"
      },
      {
        "fileMatch": "*.http_loadbalancer.json",
        "url": "f5xc-schema://schemas/http_loadbalancer.json"
      },
      {
        "fileMatch": "*.origin_pool.json",
        "url": "f5xc-schema://schemas/origin_pool.json"
      },
      {
        "fileMatch": "*.app_firewall.json",
        "url": "f5xc-schema://schemas/app_firewall.json"
      },
      {
        "fileMatch": "*.healthcheck.json",
        "url": "f5xc-schema://schemas/healthcheck.json"
      },
      {
        "fileMatch": "*.tcp_loadbalancer.json",
        "url": "f5xc-schema://schemas/tcp_loadbalancer.json"
      },
      {
        "fileMatch": "*.dns_load_balancer.json",
        "url": "f5xc-schema://schemas/dns_load_balancer.json"
      },
      {
        "fileMatch": "*.virtual_site.json",
        "url": "f5xc-schema://schemas/virtual_site.json"
      }
    ],
    "languageModelTools": [
      {
        "name": "f5xc-readFile",
        "displayName": "%tool.readFile.displayName%",
        "modelDescription": "Read the contents of a file in the workspace. Use when you need to examine source code, configuration files, or any text file. Returns the full file content as text.",
        "userDescription": "%tool.readFile.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "readFile",
        "icon": "$(file)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or workspace-relative file path"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "f5xc-getSelection",
        "displayName": "%tool.getSelection.displayName%",
        "modelDescription": "Get the currently selected text in the active editor. Use when the user references 'this code' or 'selected text'. Returns empty string if no selection.",
        "userDescription": "%tool.getSelection.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "getSelection",
        "icon": "$(selection)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "f5xc-getDiagnostics",
        "displayName": "%tool.getDiagnostics.displayName%",
        "modelDescription": "Get compiler errors, warnings, and linter diagnostics for a specific file. Use when investigating build errors or code quality issues. Returns an array of diagnostics with severity, line number, message, and source.",
        "userDescription": "%tool.getDiagnostics.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "diagnostics",
        "icon": "$(warning)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or workspace-relative file path"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "f5xc-openFile",
        "displayName": "%tool.openFile.displayName%",
        "modelDescription": "Open a file in the VS Code editor, optionally at a specific line number. Use when you want to show the user a specific file or location in the codebase.",
        "userDescription": "%tool.openFile.userDescription%",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "openFile",
        "icon": "$(go-to-file)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "File path to open"
            },
            "line": {
              "type": "number",
              "description": "Line number to reveal (optional)"
            }
          },
          "required": [
            "path"
          ]
        }
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "f5xc",
        "displayName": "xcsh"
      }
    ],
    "chatParticipants": [
      {
        "id": "f5xc.xcsh",
        "name": "xcsh",
        "fullName": "xcsh",
        "description": "%chat.xcsh.description%",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "%chat.xcsh.command.status%"
          },
          {
            "name": "context",
            "description": "%chat.xcsh.command.context%"
          },
          {
            "name": "resources",
            "description": "%chat.xcsh.command.resources%"
          }
        ],
        "disambiguation": [
          {
            "category": "f5xc_networking",
            "description": "%chat.xcsh.disambiguation.networking%",
            "examples": [
              "Create an HTTP load balancer",
              "What origin pools are configured?",
              "Show me the route table for this namespace"
            ]
          },
          {
            "category": "f5xc_security",
            "description": "%chat.xcsh.disambiguation.security%",
            "examples": [
              "Configure a WAF policy for my app",
              "Show blocked requests in the last hour",
              "What service policies are active?"
            ]
          },
          {
            "category": "f5xc_infrastructure",
