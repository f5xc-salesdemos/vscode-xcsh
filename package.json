{
  "name": "f5xc-tools",
  "displayName": "F5 XC Platform Tools",
  "description": "Manage F5 Distributed Cloud resources directly from VS Code",
  "version": "2.2605.250124",
  "publisher": "f5xc-salesdemos",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/f5xc-salesdemos/vscode-f5xc-tools"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "f5",
    "distributed cloud",
    "f5xc",
    "xc",
    "kubernetes",
    "load balancer",
    "waf",
    "cdn"
  ],
  "icon": "resources/f5-icon.png",
  "galleryBanner": {
    "color": "#e01f27",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "F5 Distributed Cloud",
      "properties": {
        "f5xc.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log level for F5 XC extension"
        },
        "f5xc.defaultNamespace": {
          "type": "string",
          "default": "default",
          "description": "Default namespace for new resources"
        },
        "f5xc.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before deleting resources"
        },
        "f5xc.deleteConfirmationLevel": {
          "type": "string",
          "enum": [
            "always",
            "high-only",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "Always show confirmation dialog for all deletes",
            "Only show confirmation for high-danger delete operations",
            "Never show confirmation dialog (use with caution)"
          ],
          "description": "When to show delete confirmation based on operation danger level"
        },
        "f5xc.autoRefreshInterval": {
          "type": "number",
          "default": 0,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        },
        "f5xc.viewMode": {
          "type": "string",
          "enum": [
            "console",
            "full"
          ],
          "default": "console",
          "description": "Resource display mode: 'console' shows clean output like F5 Console, 'full' shows complete API response"
        },
        "f5xc.showPreviewApis": {
          "type": "boolean",
          "default": true,
          "description": "Show preview/beta APIs in the explorer. Preview APIs are marked with 🧪 badge."
        },
        "f5xc.xcsh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable xcsh shell assistant integration"
        },
        "f5xc.xcsh.path": {
          "type": "string",
          "default": "",
          "description": "Custom path to the xcsh binary. Leave empty for auto-detection."
        },
        "f5xc.xcsh.chatParticipantEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Register @xcsh as a Copilot Chat participant"
        },
        "f5xc.xcsh.languageModelEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Register xcsh as a VS Code language model provider"
        },
        "f5xc.xcsh.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the xcsh process on extension activation"
        },
        "f5xc.xcsh.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default AI model for xcsh sessions"
        },
        "f5xc.xcsh.thinkingLevel": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "medium",
          "description": "Thinking level for xcsh AI responses"
        },
        "f5xc.xcsh.panelMode": {
          "type": "string",
          "enum": [
            "webview",
            "terminal"
          ],
          "default": "webview",
          "enumDescriptions": [
            "Rich integrated chat panel (recommended)",
            "Classic CLI terminal experience"
          ],
          "description": "xcsh panel experience: rich webview or classic CLI terminal"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "f5xc-explorer",
          "title": "F5 Distributed Cloud",
          "icon": "resources/f5-icon.svg"
        },
        {
          "id": "xcsh-panel",
          "title": "xcsh",
          "icon": "resources/pi-icon.svg",
          "when": "f5xc:doesNotSupportSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "xcsh-panel-secondary",
          "title": "xcsh",
          "icon": "resources/pi-icon.svg",
          "when": "!f5xc:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "xcsh-panel": [
        {
          "id": "f5xc.xcshPanel",
          "name": "xcsh",
          "type": "webview",
          "when": "f5xc:doesNotSupportSecondarySidebar"
        }
      ],
      "xcsh-panel-secondary": [
        {
          "id": "f5xc.xcshPanelSecondary",
          "name": "xcsh",
          "type": "webview",
          "when": "!f5xc:doesNotSupportSecondarySidebar"
        }
      ],
      "f5xc-explorer": [
        {
          "id": "f5xc.profiles",
          "name": "Contexts",
          "contextualTitle": "F5 XC Contexts"
        },
        {
          "id": "f5xc.subscription",
          "name": "Subscription",
          "contextualTitle": "F5 XC Subscription",
          "when": "f5xc.hasActiveContext"
        },
        {
          "id": "f5xc.explorer",
          "name": "Resources",
          "contextualTitle": "F5 XC Resources"
        },
        {
          "id": "f5xc.cloudStatus",
          "name": "Cloud Status",
          "contextualTitle": "F5 Cloud Status"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "f5xc.explorer",
        "contents": "No F5 XC context configured.\n[Add Context](command:f5xc.addContext)\nLearn more about [F5 Distributed Cloud](https://www.f5.com/cloud).",
        "when": "!f5xc.hasActiveContext"
      }
    ],
    "commands": [
      {
        "command": "f5xc.addContext",
        "title": "Add Context",
        "category": "F5 XC",
        "icon": "$(add)"
      },
      {
        "command": "f5xc.editContext",
        "title": "Edit Context",
        "category": "F5 XC",
        "icon": "$(edit)"
      },
      {
        "command": "f5xc.deleteContext",
        "title": "Delete Context",
        "category": "F5 XC",
        "icon": "$(trash)"
      },
      {
        "command": "f5xc.setActiveContext",
        "title": "Set as Active Context",
        "category": "F5 XC",
        "icon": "$(check)"
      },
      {
        "command": "f5xc.clearAuthCache",
        "title": "Clear Authentication Cache",
        "category": "F5 XC",
        "icon": "$(clear-all)"
      },
      {
        "command": "f5xc.refresh",
        "title": "Refresh",
        "category": "F5 XC",
        "icon": "$(refresh)"
      },
      {
        "command": "f5xc.create",
        "title": "Create Resource",
        "category": "F5 XC",
        "icon": "$(add)"
      },
      {
        "command": "f5xc.get",
        "title": "View Resource",
        "category": "F5 XC",
        "icon": "$(eye)"
      },
      {
        "command": "f5xc.describe",
        "title": "Describe Resource",
        "category": "F5 XC",
        "icon": "$(info)"
      },
      {
        "command": "f5xc.edit",
        "title": "Edit Resource",
        "category": "F5 XC",
        "icon": "$(edit)"
      },
      {
        "command": "f5xc.delete",
        "title": "Delete Resource",
        "category": "F5 XC",
        "icon": "$(trash)"
      },
      {
        "command": "f5xc.deleteNamespace",
        "title": "Delete Namespace",
        "category": "F5 XC",
        "icon": "$(trash)"
      },
      {
        "command": "f5xc.describeNamespace",
        "title": "Describe Namespace",
        "category": "F5 XC",
        "icon": "$(info)"
      },
      {
        "command": "f5xc.apply",
        "title": "Apply",
        "category": "F5 XC",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "f5xc.diff",
        "title": "Compare with Remote",
        "category": "F5 XC",
        "icon": "$(diff)"
      },
      {
        "command": "f5xc.copyName",
        "title": "Copy Name",
        "category": "F5 XC"
      },
      {
        "command": "f5xc.copyAsJson",
        "title": "Copy as JSON",
        "category": "F5 XC"
      },
      {
        "command": "f5xc.viewLogs",
        "title": "View Logs",
        "category": "F5 XC",
        "icon": "$(output)"
      },
      {
        "command": "f5xc.viewMetrics",
        "title": "View Metrics",
        "category": "F5 XC",
        "icon": "$(graph)"
      },
      {
        "command": "f5xc.diagram",
        "title": "Generate Diagram",
        "category": "F5 XC",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "f5xc.createFromTemplate",
        "title": "New from Template",
        "category": "F5 XC",
        "icon": "$(file-add)"
      },
      {
        "command": "f5xc.openInBrowser",
        "title": "Open in Browser",
        "category": "F5 XC",
        "icon": "$(link-external)"
      },
      {
        "command": "f5xc.toggleViewMode",
        "title": "Toggle View Mode (Console/Full)",
        "category": "F5 XC",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "f5xc.cloudStatus.refresh",
        "title": "Refresh Cloud Status",
        "category": "F5 XC",
        "icon": "$(refresh)"
      },
      {
        "command": "f5xc.cloudStatus.openDashboard",
        "title": "Open Cloud Status Dashboard",
        "category": "F5 XC",
        "icon": "$(dashboard)"
      },
      {
        "command": "f5xc.cloudStatus.openExternal",
        "title": "Open Status Page in Browser",
        "category": "F5 XC",
        "icon": "$(link-external)"
      },
      {
        "command": "f5xc.cloudStatus.viewMaintenance",
        "title": "View Maintenance Details",
        "category": "F5 XC",
        "icon": "$(info)"
      },
      {
        "command": "f5xc.cloudStatus.viewIncident",
        "title": "View Incident Details",
        "category": "F5 XC",
        "icon": "$(warning)"
      },
      {
        "command": "f5xc.cloudStatus.viewComponent",
        "title": "View Service Details",
        "category": "F5 XC",
        "icon": "$(server)"
      },
      {
        "command": "f5xc.cloudStatus.viewPoP",
        "title": "View PoP Details",
        "category": "F5 XC",
        "icon": "$(globe)"
      },
      {
        "command": "f5xc.showPlan",
        "title": "Show Subscription Plan",
        "category": "F5 XC",
        "icon": "$(file-text)"
      },
      {
        "command": "f5xc.showQuotas",
        "title": "Show Quota Usage",
        "category": "F5 XC",
        "icon": "$(graph)"
      },
      {
        "command": "f5xc.activateAddon",
        "title": "Activate Addon Service",
        "category": "F5 XC",
        "icon": "$(rocket)"
      },
      {
        "command": "f5xc.createHealthcheckForm",
        "title": "Create Healthcheck (Form)",
        "category": "F5 XC",
        "icon": "$(add)"
      },
      {
        "command": "f5xc.xcsh.openTerminal",
        "title": "Open xcsh Terminal",
        "category": "F5 XC",
        "icon": "$(terminal)"
      },
      {
        "command": "f5xc.xcsh.restart",
        "title": "Restart xcsh",
        "category": "F5 XC",
        "icon": "$(debug-restart)"
      },
      {
        "command": "f5xc.xcsh.openPanel",
        "title": "Open xcsh Panel",
        "category": "F5 XC",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "f5xc.xcsh.newSession",
        "title": "New xcsh Session",
        "category": "F5 XC",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "f5xc.refresh",
          "when": "view == f5xc.explorer",
          "group": "navigation@1"
        },
        {
          "command": "f5xc.addContext",
          "when": "view == f5xc.profiles",
          "group": "navigation"
        },
        {
          "command": "f5xc.cloudStatus.refresh",
          "when": "view == f5xc.cloudStatus",
          "group": "navigation@1"
        },
        {
          "command": "f5xc.cloudStatus.openDashboard",
          "when": "view == f5xc.cloudStatus",
          "group": "navigation@2"
        },
        {
          "command": "f5xc.cloudStatus.openExternal",
          "when": "view == f5xc.cloudStatus",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "f5xc.setActiveContext",
          "when": "view == f5xc.profiles && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "f5xc.editContext",
          "when": "view == f5xc.profiles && viewItem == profile",
          "group": "1_profile@1"
        },
        {
          "command": "f5xc.deleteContext",
          "when": "view == f5xc.profiles && viewItem == profile",
          "group": "1_profile@2"
        },
        {
          "command": "f5xc.refresh",
          "when": "view == f5xc.explorer && viewItem =~ /namespace|category/",
          "group": "inline"
        },
        {
          "command": "f5xc.create",
          "when": "view == f5xc.explorer && viewItem =~ /resourceType/ && viewItem != resourceType:healthcheck",
          "group": "inline"
        },
        {
          "command": "f5xc.createHealthcheckForm",
          "when": "view == f5xc.explorer && viewItem == resourceType:healthcheck",
          "group": "inline"
        },
        {
          "command": "f5xc.createHealthcheckForm",
          "when": "view == f5xc.explorer && viewItem == resourceType:healthcheck",
          "group": "1_create@1"
        },
        {
          "command": "f5xc.describe",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@1"
        },
        {
          "command": "f5xc.get",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@2"
        },
        {
          "command": "f5xc.edit",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@3"
        },
        {
          "command": "f5xc.delete",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "1_resource@4"
        },
        {
          "command": "f5xc.deleteNamespace",
          "when": "view == f5xc.explorer && viewItem == namespace:custom",
          "group": "1_namespace@1"
        },
        {
          "command": "f5xc.describeNamespace",
          "when": "view == f5xc.explorer && viewItem =~ /namespace:/",
          "group": "1_namespace@2"
        },
        {
          "command": "f5xc.diff",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "2_compare@1"
        },
        {
          "command": "f5xc.copyName",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "3_copy@1"
        },
        {
          "command": "f5xc.copyAsJson",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "3_copy@2"
        },
        {
          "command": "f5xc.viewLogs",
          "when": "view == f5xc.explorer && viewItem =~ /resource:http_loadbalancer|resource:tcp_loadbalancer/",
          "group": "4_observe@1"
        },
        {
          "command": "f5xc.viewMetrics",
          "when": "view == f5xc.explorer && viewItem =~ /resource:http_loadbalancer|resource:tcp_loadbalancer|resource:origin_pool/",
          "group": "4_observe@2"
        },
        {
          "command": "f5xc.diagram",
          "when": "view == f5xc.explorer && viewItem =~ /resource:http_loadbalancer/",
          "group": "4_observe@3"
        },
        {
          "command": "f5xc.openInBrowser",
          "when": "view == f5xc.explorer && viewItem =~ /resource:/",
          "group": "5_external@1"
        },
        {
          "command": "f5xc.showPlan",
          "when": "view == f5xc.subscription && viewItem == subscriptionPlan",
          "group": "inline"
        },
        {
          "command": "f5xc.showQuotas",
          "when": "view == f5xc.subscription && viewItem == subscriptionQuotas",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "f5xc.apply",
          "when": "resourceExtname == .f5xc.json || resourceFilename =~ /.*\\.(http_loadbalancer|origin_pool|app_firewall)\\.json$/",
          "group": "navigation"
        },
        {
          "command": "f5xc.diff",
          "when": "resourceExtname == .f5xc.json || resourceFilename =~ /.*\\.(http_loadbalancer|origin_pool|app_firewall)\\.json$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "f5xc.setActiveContext",
          "when": "false"
        },
        {
          "command": "f5xc.copyName",
          "when": "false"
        },
        {
          "command": "f5xc.copyAsJson",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "f5xc.apply",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && resourceExtname == .json"
      },
      {
        "command": "f5xc.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view == f5xc.explorer"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.f5xc.json",
        "url": "f5xc-schema://schemas/generic.json"
      },
      {
        "fileMatch": "*.http_loadbalancer.json",
        "url": "f5xc-schema://schemas/http_loadbalancer.json"
      },
      {
        "fileMatch": "*.origin_pool.json",
        "url": "f5xc-schema://schemas/origin_pool.json"
      },
      {
        "fileMatch": "*.app_firewall.json",
        "url": "f5xc-schema://schemas/app_firewall.json"
      },
      {
        "fileMatch": "*.healthcheck.json",
        "url": "f5xc-schema://schemas/healthcheck.json"
      },
      {
        "fileMatch": "*.tcp_loadbalancer.json",
        "url": "f5xc-schema://schemas/tcp_loadbalancer.json"
      },
      {
        "fileMatch": "*.dns_load_balancer.json",
        "url": "f5xc-schema://schemas/dns_load_balancer.json"
      },
      {
        "fileMatch": "*.virtual_site.json",
        "url": "f5xc-schema://schemas/virtual_site.json"
      }
    ],
    "languageModelTools": [
      {
        "name": "f5xc-readFile",
        "displayName": "Read File",
        "modelDescription": "Read the contents of a file in the workspace. Use when you need to examine source code, configuration files, or any text file. Returns the full file content as text.",
        "userDescription": "Read a file from the workspace",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "readFile",
        "icon": "$(file)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or workspace-relative file path"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "f5xc-getSelection",
        "displayName": "Get Editor Selection",
        "modelDescription": "Get the currently selected text in the active editor. Use when the user references 'this code' or 'selected text'. Returns empty string if no selection.",
        "userDescription": "Get selected text from the editor",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "getSelection",
        "icon": "$(selection)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "f5xc-getDiagnostics",
        "displayName": "Get File Diagnostics",
        "modelDescription": "Get compiler errors, warnings, and linter diagnostics for a specific file. Use when investigating build errors or code quality issues. Returns an array of diagnostics with severity, line number, message, and source.",
        "userDescription": "Get errors and warnings for a file",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "diagnostics",
        "icon": "$(warning)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or workspace-relative file path"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "f5xc-openFile",
        "displayName": "Open File in Editor",
        "modelDescription": "Open a file in the VS Code editor, optionally at a specific line number. Use when you want to show the user a specific file or location in the codebase.",
        "userDescription": "Open a file in the editor",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "openFile",
        "icon": "$(go-to-file)",
        "tags": [
          "f5xc"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "File path to open"
            },
            "line": {
              "type": "number",
              "description": "Line number to reveal (optional)"
            }
          },
          "required": [
            "path"
          ]
        }
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "f5xc",
        "displayName": "F5 XC Shell Assistant"
      }
    ],
    "chatParticipants": [
      {
        "id": "f5xc.xcsh",
        "name": "xcsh",
        "fullName": "F5 XC Shell Assistant",
        "description": "Ask about F5 Distributed Cloud resources, configuration, and troubleshooting",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Show F5 XC integration health and connection status"
          },
          {
            "name": "context",
            "description": "Show active F5 XC context details (tenant, namespace, API URL)"
          },
          {
            "name": "resources",
            "description": "List resources in the current namespace"
          }
        ],
        "disambiguation": [
          {
            "category": "f5xc_networking",
            "description": "Questions about F5 Distributed Cloud networking, load balancers, origin pools, routes, DNS, CDN, virtual hosts, and HTTP load balancer configuration",
            "examples": [
              "Create an HTTP load balancer",
              "What origin pools are configured?",
              "Show me the route table for this namespace"
            ]
          },
          {
            "category": "f5xc_security",
            "description": "Questions about F5 Distributed Cloud security, WAF policies, service policies, DDoS protection, bot defense, API security, and application firewall configuration",
            "examples": [
              "Configure a WAF policy for my app",
              "Show blocked requests in the last hour",
              "What service policies are active?"
            ]
          },
          {
            "category": "f5xc_infrastructure",
            "description": "Questions about F5 Distributed Cloud sites, site health, cloud connectors, network connectors, fleet management, and infrastructure status",
            "examples": [
              "Check site health for my AWS site",
              "List all registered sites",
              "Show cloud connector status"
            ]
          }
        ]
      }
    ],
    "chatSkills": [
      {
